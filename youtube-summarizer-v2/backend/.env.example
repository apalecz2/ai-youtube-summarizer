# ── Web app auth ──────────────────────────────────────────────
# Single-user login for the web UI. Store a hash, not the plaintext.
# Generate one: python -c "import hashlib,os;print(hashlib.sha256(b'YOUR_PASSWORD').hexdigest())"
APP_PASSWORD_SHA256=replace_with_sha256_hex
# Secret used to sign session cookies (any long random string)
SESSION_SECRET=replace_with_long_random_string

# API token for the browser extension / scripts (X-API-Key header)
API_AUTH_TOKEN=replace_with_random_hex

# Public base URL of the web app, used for "Open in app" links in summary emails.
# Leave blank to omit the link. e.g. https://summarizer.example.com
APP_BASE_URL=

# Comma-separated origins allowed to call the API with credentials (dev SPA).
# Not needed in production (SPA is served same-origin by FastAPI).
CORS_ORIGINS=http://localhost:5173

# ── Gemini ────────────────────────────────────────────────────
GEMINI_API_KEY=replace_me

# ── Gmail (OAuth2 SMTP) ───────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=you@gmail.com
EMAIL_SENDTO=you@example.com
GMAIL_CLIENT_ID=replace_me
GMAIL_CLIENT_SECRET=replace_me
GMAIL_REFRESH_TOKEN=replace_me

# ── YouTube / anti-bot ────────────────────────────────────────
# Path to a Netscape-format cookies.txt exported from the DEDICATED throwaway
# Google account. Mounted into the container as a volume.
YTDLP_COOKIES_FILE=data/cookies.txt

# Escape an IP rate-limit (HTTP 429) without code changes. If YouTube flags this
# server's IP, metadata may still load but subtitle downloads get 429'd — surfacing
# as "no transcript". Route traffic through a clean egress IP:
#   YTDLP_PROXY: e.g. http://user:pass@host:port (rotating proxy / relay VPS)
#   YTDLP_IMPERSONATE: a curl_cffi browser target, e.g. chrome:windows-10
#     (requires the curl_cffi package; clears front-door bot checks)
YTDLP_PROXY=
YTDLP_IMPERSONATE=

# Discovery cadence (minutes) and the window transcript fetches are spread over.
POLL_INTERVAL_MINUTES=30
# Fetches are scheduled randomly within this many minutes of discovery.
FETCH_SPREAD_MINUTES=28
# Min/max extra random gap (seconds) the worker waits between YouTube calls.
FETCH_JITTER_MIN_SECONDS=20
FETCH_JITTER_MAX_SECONDS=90

# ── Backoff (item 6) ──────────────────────────────────────────
# Exponential schedule (minutes), comma-separated. Last value repeats (capped).
BACKOFF_SCHEDULE_MINUTES=5,15,45,120,360,720
